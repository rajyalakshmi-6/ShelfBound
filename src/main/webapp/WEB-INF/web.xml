<!-- ========================= -->
<!-- ADMIN /user LOGOUT -->
<!-- ========================= -->

<servlet>
    <servlet-name>LogoutServlet</servlet-name>  <!-- we can give any name servlet class must br correct -->
    <servlet-class>com.shelfbound.servlet.admin.LogoutServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
</servlet-mapping>


<servlet>
    <servlet-name>AboutServlet</servlet-name>
    <servlet-class>com.shelfbound.servlet.AboutServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AboutServlet</servlet-name>
    <url-pattern>/about</url-pattern>
</servlet-mapping>

    <!-- ========================= -->
    <!-- DEFAULT WELCOME PAGE -->
    <!-- ========================= -->

    <welcome-file-list>

        <!-- OPEN HOME PAGE FIRST -->
        <welcome-file>home</welcome-file>

    </welcome-file-list>

</web-app>